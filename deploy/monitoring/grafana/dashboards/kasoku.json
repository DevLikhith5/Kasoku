{
  "title": "Kasoku Distributed Storage",
  "uid": "kasoku-main",
  "refresh": "5s",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "stat",
      "title": "Requests (ops/sec)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(rate(kasoku_requests_total[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Keys",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "kasoku_storage_engine_keys_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-grYlRd"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Cluster Nodes",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "kasoku_cluster_nodes_active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Operations Throughput",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (operation) (rate(kasoku_requests_total[1m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "95th Percentile Latency",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(kasoku_request_duration_seconds_bucket[5m])) by (operation, le))",
          "legendFormat": "{{operation}} (p95)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "kasoku_storage_engine_bytes",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cluster Phi Suspicion",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "kasoku_cluster_phi_suspicion",
          "legendFormat": "Node {{node_id}}",
          "refId": "A"
        }
      ]
    }
  ]
}